#!/bin/sh
# serial_driver_epoch_rotate - Force epoch boundary with in-flight messages
# Runs serially (one at a time), causing disruptive state transitions.
#
# This script exercises the epoch-boundary race condition where messages
# may be in-flight during key rotation.

set -e

echo "serial_driver_epoch_rotate: forcing epoch rotation..."

# Get initial epoch from relay-1
initial_epoch=$(wget -qO- "http://relay-1:7000/status" 2>/dev/null | grep -o '"current_epoch":[0-9]*' | cut -d: -f2)
echo "serial_driver_epoch_rotate: initial epoch = ${initial_epoch:-unknown}"

# Get initial message count from pool
initial_count=$(wget -qO- "http://message-pool:8080/messages" 2>/dev/null | grep -o '"count":[0-9]*' | cut -d: -f2)
echo "serial_driver_epoch_rotate: initial message count = ${initial_count:-0}"

# Phase 1: Send messages BEFORE epoch rotation
echo "serial_driver_epoch_rotate: sending pre-rotation messages..."
for i in 1 2 3; do
    # Send test message via relay (will go to validator, then to pool)
    # Using a simple ciphertext for testing
    test_ciphertext=$(printf "pre-rotation-msg-%d-%d" "$i" "$(date +%s%N)" | base64)

    curl -s -X POST "http://relay-1:7000/forward" \
        -H "Content-Type: application/json" \
        -d "{\"id\":\"pre-rotate-$i\",\"nonce\":\"$(head -c 24 /dev/urandom | base64)\",\"sender_pub_key\":\"$(head -c 32 /dev/urandom | base64)\",\"ciphertext\":\"$test_ciphertext\"}" \
        >/dev/null 2>&1 || true
done

# Phase 2: Force epoch rotation on all relays
echo "serial_driver_epoch_rotate: forcing epoch advance..."
for relay in relay-1 relay-2 relay-3 relay-4 relay-5; do
    result=$(curl -s -X POST "http://${relay}:7000/epoch/advance" 2>/dev/null || echo "{}")
    new_epoch=$(echo "$result" | grep -o '"current_epoch":[0-9]*' | cut -d: -f2)
    if [ -n "$new_epoch" ]; then
        echo "serial_driver_epoch_rotate: $relay advanced to epoch $new_epoch"
    fi
done

# Phase 3: Send messages DURING/AFTER epoch rotation (potential race condition)
echo "serial_driver_epoch_rotate: sending mid-rotation messages..."
for i in 1 2 3; do
    test_ciphertext=$(printf "mid-rotation-msg-%d-%d" "$i" "$(date +%s%N)" | base64)

    curl -s -X POST "http://relay-2:7000/forward" \
        -H "Content-Type: application/json" \
        -d "{\"id\":\"mid-rotate-$i\",\"nonce\":\"$(head -c 24 /dev/urandom | base64)\",\"sender_pub_key\":\"$(head -c 32 /dev/urandom | base64)\",\"ciphertext\":\"$test_ciphertext\"}" \
        >/dev/null 2>&1 || true
done

# Phase 4: Wait briefly then verify key rotation occurred
sleep 2

# Get new epoch and verify it advanced
new_epoch=$(wget -qO- "http://relay-1:7000/status" 2>/dev/null | grep -o '"current_epoch":[0-9]*' | cut -d: -f2)
echo "serial_driver_epoch_rotate: new epoch = ${new_epoch:-unknown}"

if [ -n "$initial_epoch" ] && [ -n "$new_epoch" ] && [ "$new_epoch" -gt "$initial_epoch" ]; then
    echo "serial_driver_epoch_rotate: key rotation confirmed (epoch $initial_epoch -> $new_epoch)"
else
    echo "serial_driver_epoch_rotate: WARNING - epoch did not advance as expected"
fi

# Phase 5: Send messages AFTER epoch rotation
echo "serial_driver_epoch_rotate: sending post-rotation messages..."
for i in 1 2 3; do
    test_ciphertext=$(printf "post-rotation-msg-%d-%d" "$i" "$(date +%s%N)" | base64)

    curl -s -X POST "http://relay-3:7000/forward" \
        -H "Content-Type: application/json" \
        -d "{\"id\":\"post-rotate-$i\",\"nonce\":\"$(head -c 24 /dev/urandom | base64)\",\"sender_pub_key\":\"$(head -c 32 /dev/urandom | base64)\",\"ciphertext\":\"$test_ciphertext\"}" \
        >/dev/null 2>&1 || true
done

# Verify no identity leakage during transition
# Check that public keys are different after rotation
old_pubkey=$(wget -qO- "http://relay-1:7000/pubkey" 2>/dev/null | grep -o '"public_key":"[^"]*"' | cut -d'"' -f4)
echo "serial_driver_epoch_rotate: relay-1 public key after rotation = ${old_pubkey:0:16}..."

# Final check: get message count from pool
sleep 1
final_count=$(wget -qO- "http://message-pool:8080/messages" 2>/dev/null | grep -o '"count":[0-9]*' | cut -d: -f2)
echo "serial_driver_epoch_rotate: final message count = ${final_count:-0}"

echo "serial_driver_epoch_rotate: epoch rotation complete"
exit 0
