#!/bin/sh
# serial_driver_byz_relay - Make one relay behave maliciously
# Runs serially, injecting byzantine behavior into the relay network.
#
# This script exercises byzantine relay behaviors: message dropping,
# delaying, corruption. The byzantine relay (relay-byzantine) is
# configured via VEIL_BYZANTINE=true environment variable.

set -e

echo "serial_driver_byz_relay: injecting byzantine relay behavior..."

# Check if byzantine relay is available
if wget -q --spider "http://relay-byzantine:7000/health" 2>/dev/null; then
    echo "serial_driver_byz_relay: byzantine relay is healthy"
    byz_relay="relay-byzantine"
else
    # Fall back to relay-5 if no dedicated byzantine relay
    echo "serial_driver_byz_relay: using relay-5 as target (no dedicated byzantine relay)"
    byz_relay="relay-5"
fi

# Track message outcomes
total_sent=0
total_accepted=0

# Send messages through the byzantine relay
# The byzantine relay will randomly: drop, delay, corrupt, or forward normally
echo "serial_driver_byz_relay: sending messages through byzantine relay..."

for i in $(seq 1 20); do
    # Generate test message
    test_ciphertext=$(printf "byz-test-msg-%d-%d" "$i" "$(date +%s%N)" | base64)
    msg_id="byz-test-$i-$(date +%s%N)"

    # Send to byzantine relay
    result=$(curl -s -X POST "http://${byz_relay}:7000/forward" \
        -H "Content-Type: application/json" \
        -d "{\"id\":\"$msg_id\",\"nonce\":\"$(head -c 24 /dev/urandom | base64)\",\"sender_pub_key\":\"$(head -c 32 /dev/urandom | base64)\",\"ciphertext\":\"$test_ciphertext\"}" \
        2>/dev/null || echo '{"accepted":false}')

    total_sent=$((total_sent + 1))

    # Check if accepted
    if echo "$result" | grep -q '"accepted":true'; then
        total_accepted=$((total_accepted + 1))
    fi

    # Small delay between messages
    sleep 0.1
done

echo "serial_driver_byz_relay: sent $total_sent messages, $total_accepted accepted"

# Also send some messages through normal relays for comparison
echo "serial_driver_byz_relay: sending control messages through normal relays..."
for i in $(seq 1 5); do
    test_ciphertext=$(printf "control-msg-%d-%d" "$i" "$(date +%s%N)" | base64)
    msg_id="control-$i-$(date +%s%N)"

    curl -s -X POST "http://relay-1:7000/forward" \
        -H "Content-Type: application/json" \
        -d "{\"id\":\"$msg_id\",\"nonce\":\"$(head -c 24 /dev/urandom | base64)\",\"sender_pub_key\":\"$(head -c 32 /dev/urandom | base64)\",\"ciphertext\":\"$test_ciphertext\"}" \
        >/dev/null 2>&1 || true

    sleep 0.05
done

# Verify system still functions despite byzantine behavior
sleep 2

# Check all relays are still healthy
healthy_count=0
for r in relay-1 relay-2 relay-3 relay-4 relay-5; do
    if wget -q --spider "http://${r}:7000/health" 2>/dev/null; then
        healthy_count=$((healthy_count + 1))
    fi
done

echo "serial_driver_byz_relay: $healthy_count/5 normal relays still healthy"

# Check anonymity set (must be >= 3 despite byzantine relay)
if [ $healthy_count -ge 3 ]; then
    echo "serial_driver_byz_relay: anonymity set maintained despite byzantine behavior"
else
    echo "serial_driver_byz_relay: WARNING - anonymity set compromised ($healthy_count < 3)"
fi

# The Antithesis properties (byzantine_input, relay_unlinkability, etc.)
# are asserted in the relay server code when byzantine behaviors execute

echo "serial_driver_byz_relay: byzantine injection complete"
exit 0
