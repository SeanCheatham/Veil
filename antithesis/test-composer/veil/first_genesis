#!/bin/sh
# first_genesis - Bootstrap relay network + validators
# This command runs once at the start of each timeline.

set -e

echo "first_genesis: bootstrapping Veil network..."

# Wait for services to be healthy
wait_for_service() {
    host=$1
    port=$2
    max_attempts=${3:-30}

    for i in $(seq 1 $max_attempts); do
        if wget -q --spider "http://${host}:${port}/health" 2>/dev/null; then
            echo "first_genesis: $host is healthy"
            return 0
        fi
        sleep 1
    done

    echo "first_genesis: WARNING - $host did not become healthy"
    return 1
}

# Check message pool
wait_for_service "message-pool" "8080"

# Check validators (we need at least 2/3 for consensus)
wait_for_service "validator-1" "9000"
wait_for_service "validator-2" "9000"
wait_for_service "validator-3" "9000"

# Check relays (we need at least 3 for anonymity threshold)
wait_for_service "relay-1" "7000" 30 || true
wait_for_service "relay-2" "7000" 30 || true
wait_for_service "relay-3" "7000" 30 || true
wait_for_service "relay-4" "7000" 30 || true
wait_for_service "relay-5" "7000" 30 || true

# Verify minimum anonymity set size by checking relay count
# Count how many relays are healthy
relay_count=0
for relay in relay-1 relay-2 relay-3 relay-4 relay-5; do
    if wget -q --spider "http://${relay}:7000/health" 2>/dev/null; then
        relay_count=$((relay_count + 1))
    fi
done

if [ $relay_count -lt 3 ]; then
    echo "first_genesis: WARNING - only $relay_count relays healthy (need 3 for anonymity)"
else
    echo "first_genesis: $relay_count relays healthy, anonymity set threshold met"
fi

echo "first_genesis: bootstrap complete"
exit 0
