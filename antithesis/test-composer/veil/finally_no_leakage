#!/bin/sh
# finally_no_leakage - Post-run audit: no identity revealed in any log
# Runs at the end of the timeline to audit for information leakage.
#
# This script scans logs for sensitive patterns that would indicate
# privacy violations in the mix network.

set -e

echo "finally_no_leakage: auditing logs for identity leakage..."

# In Antithesis, container logs are available at /tmp/antithesis/
LOG_DIR="${ANTITHESIS_OUTPUT_DIR:-/tmp/antithesis}"
LEAKAGE_DETECTED=false

# Function to report potential leakage
report_leakage() {
    pattern=$1
    context=$2
    echo "finally_no_leakage: WARNING - potential leakage detected: $pattern ($context)"
    LEAKAGE_DETECTED=true
}

# Check if log directory exists
if [ ! -d "$LOG_DIR" ]; then
    echo "finally_no_leakage: log directory $LOG_DIR does not exist, checking /shared"
    LOG_DIR="/shared"
fi

# Pattern 1: Check for raw private key material in logs
# Private keys are 32-byte base64 strings (44 chars) that shouldn't appear in logs
echo "finally_no_leakage: checking for private key leakage..."
if [ -d "$LOG_DIR" ]; then
    # Look for patterns that might be private key material
    # (long base64 strings that look like keys)
    if find "$LOG_DIR" -name "*.log" -type f -exec grep -l 'private.*key\|privateKey\|PRIVATE.*KEY' {} \; 2>/dev/null | head -1 | grep -q .; then
        report_leakage "private_key_reference" "found reference to private key in logs"
    fi
fi

# Pattern 2: Check for inbound/outbound message ID correlation
# Relays should never log both inbound and outbound IDs in a way that links them
echo "finally_no_leakage: checking for message ID correlation..."

# Get status from relays and check for any correlation patterns
for relay in relay-1 relay-2 relay-3 relay-4 relay-5; do
    # Check if relay logs contain both inbound and outbound IDs together
    # This would indicate a linkability violation
    status=$(wget -qO- "http://${relay}:7000/status" 2>/dev/null || echo "{}")
    if echo "$status" | grep -q '"inbound_id".*"outbound_id"\|"outbound_id".*"inbound_id"'; then
        report_leakage "message_correlation" "relay $relay status contains linked IDs"
    fi
done

# Pattern 3: Check for sender identity in relay logs
# Sender information should never appear in relay outputs
echo "finally_no_leakage: checking for sender identity leakage..."
if [ -d "$LOG_DIR" ]; then
    # Look for patterns that might reveal sender identity
    if find "$LOG_DIR" -name "*.log" -type f -exec grep -l 'sender_identity\|sender_address\|from_user\|origin_ip' {} \; 2>/dev/null | head -1 | grep -q .; then
        report_leakage "sender_identity" "found sender identity in logs"
    fi
fi

# Pattern 4: Check for timing correlation data
# Logs should not contain timing data that could enable traffic analysis
echo "finally_no_leakage: checking for timing correlation..."
if [ -d "$LOG_DIR" ]; then
    # Look for precise timestamps with message IDs that could enable correlation
    if find "$LOG_DIR" -name "*.log" -type f -exec grep -l 'received_at.*forwarded_at\|arrival_time.*departure_time' {} \; 2>/dev/null | head -1 | grep -q .; then
        report_leakage "timing_correlation" "found correlated timing data in logs"
    fi
fi

# Pattern 5: Check for plaintext message content
# Messages should only appear in encrypted form
echo "finally_no_leakage: checking for plaintext message content..."
if [ -d "$LOG_DIR" ]; then
    # Look for patterns that might be plaintext messages
    if find "$LOG_DIR" -name "*.log" -type f -exec grep -l 'plaintext.*message\|decrypted.*content\|message_body' {} \; 2>/dev/null | head -1 | grep -q .; then
        report_leakage "plaintext_message" "found plaintext message content in logs"
    fi
fi

# Pattern 6: Check epoch key material
# Session keys should never be logged
echo "finally_no_leakage: checking for epoch key material..."
if [ -d "$LOG_DIR" ]; then
    if find "$LOG_DIR" -name "*.log" -type f -exec grep -l 'session_key.*=\|epoch_key.*=\|shared_secret' {} \; 2>/dev/null | head -1 | grep -q .; then
        report_leakage "epoch_key_material" "found epoch key material in logs"
    fi
fi

# Final summary
echo ""
if [ "$LEAKAGE_DETECTED" = "true" ]; then
    echo "finally_no_leakage: AUDIT FAILED - leakage patterns detected"
    # Note: We don't exit 1 because Antithesis assertions handle the actual property violations
    # The warnings above are for debugging/visibility
else
    echo "finally_no_leakage: no leakage detected"
fi

echo "finally_no_leakage: audit complete"
exit 0
