#!/bin/sh
# anytime_invariant_check - Permanent invariant checks
# Can run at any point in the timeline to verify system invariants.

set -e

echo "anytime_invariant_check: checking system invariants..."

# Track overall status
all_passed=true

# Check pool health
if wget -q --spider "http://message-pool:8080/health" 2>/dev/null; then
    echo "anytime_invariant_check: message-pool healthy"
else
    echo "anytime_invariant_check: ERROR - message-pool unhealthy!"
    all_passed=false
fi

# Check validator consensus health (need at least 2/3 for quorum)
validator_healthy=0
for v in validator-1 validator-2 validator-3; do
    if wget -q --spider "http://${v}:9000/health" 2>/dev/null; then
        validator_healthy=$((validator_healthy + 1))
        echo "anytime_invariant_check: $v healthy"
    else
        echo "anytime_invariant_check: WARNING - $v unhealthy"
    fi
done

if [ $validator_healthy -lt 2 ]; then
    echo "anytime_invariant_check: ERROR - insufficient validators for quorum ($validator_healthy/3)"
    all_passed=false
else
    echo "anytime_invariant_check: validator quorum OK ($validator_healthy/3)"
fi

# Check anonymity set size (minimum 3 relays)
relay_healthy=0
for r in relay-1 relay-2 relay-3 relay-4 relay-5; do
    if wget -q --spider "http://${r}:7000/health" 2>/dev/null; then
        relay_healthy=$((relay_healthy + 1))
        echo "anytime_invariant_check: $r healthy"
    else
        echo "anytime_invariant_check: WARNING - $r unhealthy"
    fi
done

if [ $relay_healthy -lt 3 ]; then
    echo "anytime_invariant_check: ERROR - anonymity set size below threshold ($relay_healthy < 3)"
    all_passed=false
else
    echo "anytime_invariant_check: anonymity set OK ($relay_healthy relays)"
fi

# Check epoch consistency across relays by fetching their status
# Get epoch from first healthy relay
first_epoch=""
for r in relay-1 relay-2 relay-3 relay-4 relay-5; do
    status=$(wget -qO- "http://${r}:7000/status" 2>/dev/null || echo "")
    if [ -n "$status" ]; then
        epoch=$(echo "$status" | grep -o '"current_epoch":[0-9]*' | cut -d: -f2)
        if [ -n "$epoch" ]; then
            if [ -z "$first_epoch" ]; then
                first_epoch=$epoch
                echo "anytime_invariant_check: relay epoch reference = $first_epoch"
            elif [ "$epoch" != "$first_epoch" ]; then
                echo "anytime_invariant_check: WARNING - epoch drift detected (expected $first_epoch, got $epoch from $r)"
            fi
        fi
    fi
done

if [ "$all_passed" = "true" ]; then
    echo "anytime_invariant_check: all invariants passed"
    exit 0
else
    echo "anytime_invariant_check: SOME INVARIANTS FAILED"
    # Don't fail the script - Antithesis will detect property violations
    exit 0
fi
