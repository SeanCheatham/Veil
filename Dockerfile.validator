# Build stage
FROM golang:1.24-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /validator ./cmd/validator

# Runtime stage
FROM alpine:3.19

COPY --from=builder /validator /usr/local/bin/validator
COPY antithesis/setup-complete.sh /usr/local/bin/setup-complete.sh
RUN chmod +x /usr/local/bin/setup-complete.sh

EXPOSE 8082

CMD ["/usr/local/bin/validator"]
